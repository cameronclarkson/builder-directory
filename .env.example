# Supabase (optional override; defaults are in code)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Required for vector migration + backfill (pnpm db:vector)
# Get from Dashboard → Project Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Required for generating embeddings (semantic search + backfill)
OPENAI_API_KEY=sk-...

# Optional: use for backfill if RLS blocks anon updates on deals/contacts
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
